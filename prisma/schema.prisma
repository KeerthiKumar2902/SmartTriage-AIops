generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Incident {
  id               String   @id @default(uuid())
  timestamp        DateTime @default(now())
  service_affected String
  raw_log          Json
  ai_root_cause    String?
  severity_score   Int?
  bash_remediation String?
  status           String   @default("OPEN")
}
